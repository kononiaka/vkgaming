{
    "rules": {
        "users": {
            ".read": true,
            "$uid": {
                ".write": "auth != null && (auth.uid === $uid || root.child('meta').child('admins').child(auth.uid).val() === true)",
                "telegramChatId": {
                    ".write": false
                },
                "telegramLinkedAt": {
                    ".write": false
                },
                "telegramUsername": {
                    ".write": false
                },
                "telegramNotificationPrefs": {
                    ".write": "auth != null && auth.uid === $uid"
                },
                "telegramFollowedPlayers": {
                    ".write": "auth != null && auth.uid === $uid"
                }
            }
        },
        "tournaments": {
            ".read": true,
            "heroes3": {
                "$tournamentId": {
                    "players": {
                        "$playerId": {
                            ".write": "auth != null && (root.child('meta').child('admins').child(auth.uid).val() === true || (!data.exists() && (!root.child('tournaments').child('heroes3').child($tournamentId).child('attendanceFeeUsd').exists() || root.child('tournaments').child('heroes3').child($tournamentId).child('attendanceFeeUsd').val() == 0 || root.child('tournaments').child('heroes3').child($tournamentId).child('attendancePaid').child(auth.uid).exists() || root.child('tournaments').child('heroes3').child($tournamentId).child('createdByUid').val() === auth.uid)) || (data.exists() && !newData.exists() && (data.child('registeredUid').val() === auth.uid || root.child('tournaments').child('heroes3').child($tournamentId).child('createdByUid').val() === auth.uid)))"
                        }
                    },
                    "commentatorRequests": {
                        "$requestUid": {
                            ".write": "auth != null && ((!data.exists() && $requestUid === auth.uid && newData.child('registeredUid').val() === auth.uid) || (data.exists() && (data.child('registeredUid').val() === auth.uid || root.child('meta').child('admins').child(auth.uid).val() === true || root.child('tournaments').child('heroes3').child($tournamentId).child('createdByUid').val() === auth.uid)))"
                        }
                    },
                    "commentators": {
                        "$commentatorUid": {
                            ".write": "auth != null && ($commentatorUid === auth.uid || root.child('meta').child('admins').child(auth.uid).val() === true || root.child('tournaments').child('heroes3').child($tournamentId).child('createdByUid').val() === auth.uid)"
                        }
                    },
                    "attendancePaid": {
                        ".read": "auth != null",
                        ".write": false
                    },
                    "bracket": {
                        ".write": "auth != null"
                    },
                    "submitProgress": {
                        ".write": "auth != null"
                    },
                    "status": {
                        ".write": "auth != null && root.child('meta').child('admins').child(auth.uid).val() === true"
                    },
                    "winners": {
                        ".write": "auth != null && root.child('meta').child('admins').child(auth.uid).val() === true"
                    },
                    "pricePull": {
                        ".write": "auth != null && root.child('meta').child('admins').child(auth.uid).val() === true"
                    },
                    ".write": "auth != null && (root.child('meta').child('admins').child(auth.uid).val() === true || (!data.exists() && newData.child('createdByUid').val() === auth.uid) || (data.exists() && !newData.exists() && data.child('createdByUid').val() === auth.uid))"
                },
                ".write": "auth != null && (root.child('meta').child('admins').child(auth.uid).val() === true || (!data.exists() && newData.child('createdByUid').val() === auth.uid))"
            }
        },
        "games": {
            ".read": true,
            ".write": "auth != null"
        },
        "progress": {
            ".read": "auth != null",
            ".write": "auth != null"
        },
        "statistic": {
            ".read": true,
            "heroes3": {
                "castles": {
                    "$castle": {
                        ".write": "auth != null"
                    }
                },
                ".write": "auth != null && root.child('meta').child('admins').child(auth.uid).val() === true"
            }
        },
        "meta": {
            ".read": "auth != null",
            ".write": "auth != null && root.child('meta').child('admins').child(auth.uid).val() === true"
        },
        "comments": {
            ".read": true,
            ".write": false
        },
        "quotes": {
            ".read": true,
            ".write": false
        },
        "starsImg": {
            ".read": true,
            ".write": false
        },
        "daTokens": {
            ".read": false,
            ".write": false
        },
        "processedDonations": {
            ".read": false,
            ".write": false
        },
        "processedStripe": {
            ".read": false,
            ".write": false
        },
        "processedBmcDonations": {
            ".read": false,
            ".write": false
        },
        "prizePoolFunding": {
            ".read": true,
            ".write": false
        },
        "bugReports": {
            ".read": "auth != null && root.child('meta').child('admins').child(auth.uid).val() === true",
            ".write": false
        }
    }
}
