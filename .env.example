# Firebase (required for auth + database)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id

# Cloud Functions base (optional — defaults from project id)
REACT_APP_FIREBASE_FUNCTIONS_BASE=https://us-central1-your-project-id.cloudfunctions.net

# Public site URL (baked into production build for OAuth redirects)
REACT_APP_SITE_URL=https://kononiaka.github.io/vkgaming

# Twitch OAuth (required for player login)
REACT_APP_TWITCH_CLIENT_ID=
REACT_APP_TWITCH_REDIRECT_URI=https://kononiaka.github.io/vkgaming/auth/twitch/callback
# Register BOTH redirect URIs in the Twitch Developer Console (must match exactly):
# https://kononiaka.github.io/vkgaming/auth/twitch/callback
# http://localhost:3000/vkgaming/auth/twitch/callback

# YouTube videos page (optional — nav hidden at launch)
REACT_APP_YOUTUBE_API_KEY=
REACT_APP_YOUTUBE_CHANNEL_ID=
REACT_APP_YOUTUBE_UPLOADS_PLAYLIST_ID=
REACT_APP_YOUTUBE_EXCLUDED_VIDEO_IDS=

# Telegram — @vkgamingplay (optional override for local dev)
REACT_APP_TELEGRAM_URL=https://t.me/vkgamingplay

# Telegram bot posting (Firebase Functions config — not React env)
# Channel digests: @vkgamingplay
# Personal DMs: @konoplay_bot (link from profile → Telegram notifications)
# firebase functions:config:set telegram.bot_token="..." telegram.channel_id="@vkgamingplay"
# Optional: telegram.bot_username="konoplay_bot" telegram.site_url="https://kononiaka.github.io/vkgaming" telegram.test_secret="..."
# After deploy, register webhook:
# curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://us-central1-<PROJECT>.cloudfunctions.net/telegramWebhook"
# Default: digest-only (h3ladder style). Morning 09:00 Kyiv; evening 18:00 only if times added after 09:00.
# Per-match instant pings: telegram.instant_notifications="true"
