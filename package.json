        "eslint-plugin-react": "^7.37.2",
        "firebase-admin": "^11.7.0",
        "firebase-functions": "^4.3.1",
        "gh-pages": "^5.0.0",
        "globals": "^15.11.0",
        "jest": "^27.5.1",
        "prettier": "latest",
        "typescript": "^4.9.5"
